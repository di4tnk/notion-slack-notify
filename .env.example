# Notion API Configuration
NOTION_TOKEN=secret_your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Notion プロパティ名（Notionデータベースの実際のプロパティ名に合わせて変更）
NOTION_NOTIFY_PROPERTY=通知する
NOTION_LAST_NOTIFIED_PROPERTY=最終通知日時
NOTION_READERS_PROPERTY=既読者
NOTION_READER_COUNT_PROPERTY=既読数

# Slack Configuration
# Bot User OAuth Token（Slack App > OAuth & Permissions > Bot User OAuth Token）
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
# 署名検証シークレット（Slack App > Basic Information > Signing Secret）
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
# 通知先チャンネル名またはチャンネルID
# テスト: development-test
# 本番:  general-announcements
SLACK_CHANNEL=development-test

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_PROJECT=your-gcp-project-id

# Development Configuration
NODE_ENV=development
PORT=8080
FUNCTIONS_TARGET=notifySlack
